# Logging
LOG_LEVEL=INFO

# Decision thresholds (uncomment to override config/config.yaml)
# RISK_APPROVAL_THRESHOLD=40
# RISK_BLOCK_ON_CRITICAL=true

# Execution mode. Paper is the safe default and uses no real funds.
# Allowed: paper | robinhood_mcp
EXECUTION_MODE=paper

# LIVE TRADING SAFETY SWITCH. Must be explicitly "true" to allow any real order.
# Leaving this unset or "false" keeps the agent in paper mode regardless of EXECUTION_MODE.
LIVE_TRADING_ENABLED=false

# Robinhood agentic trading (MCP). Only used when EXECUTION_MODE=robinhood_mcp AND
# LIVE_TRADING_ENABLED=true. Provide credentials via environment/secret store only.
# ROBINHOOD_MCP_ENDPOINT=
# ROBINHOOD_MCP_API_KEY=
# ROBINHOOD_AGENTIC_ACCOUNT_ID=

# Optional collective memory
# MEMORY_ENABLED=false
# MEMORY_PATH=.agent_memory/memory.db

# Optional news provider (company daily news). Offline fixtures are used by default.
# Allowed: offline | live
NEWS_PROVIDER=offline
# NEWS_API_KEY=

# Optional LLM for narrative enrichment only (never changes decisions)
LLM_PROVIDER=none
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE=
